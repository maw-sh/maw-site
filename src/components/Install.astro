<style>
  .bigcmd .cp{margin-left:10px;color:var(--dim);font-size:12px;border:1px solid var(--line);border-radius:6px;padding:3px 8px}
</style>

<script>
  for (const el of document.querySelectorAll('#copyHero, #copyBig')) {
    el.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText('brew install --cask maw-sh/maw/maw'); } catch {}
      const c = el.querySelector('.cp');
      if (c) { const t = c.textContent; c.textContent = 'copied ✓'; setTimeout(() => { c.textContent = t; }, 1200); }
    });
  }
</script>

<section class="section" id="install">
  <div class="band">
    <div class="label">Install</div>
    <h2>Two minutes to your first Nest.</h2>
    <div class="bigcmd" id="copyBig" style="cursor:pointer"><span class="pr">$</span> brew install --cask maw-sh/maw/maw<span class="cp">copy</span></div>
    <p class="sub" style="margin:0 auto">Developer ID-signed &amp; notarized. macOS only. Free &amp; open source under Apache-2.0.</p>
    <div class="cta" style="justify-content:center;margin-top:22px"><a class="btn primary" href="https://github.com/maw-sh/maw" target="_blank" rel="noopener">View source on GitHub</a><a class="btn" href="https://github.com/maw-sh/maw#readme" target="_blank" rel="noopener">Read the docs</a></div>
  </div>
</section>
